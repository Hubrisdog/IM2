datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Species {
  id               Int               @id @default(autoincrement())
  species_name     String            @unique @db.VarChar(100)
  incidentReports  Incident_Report[]
  animals          Animal[]
}

model Role {
  id        Int      @id @default(autoincrement())
  role_name String   @unique @db.VarChar(100)
  agents    Agent[]
}

model Shelter {
  id             Int       @id @default(autoincrement())
  shelter_name   String    @db.VarChar(100)
  capacity       Int
  address        String    @db.VarChar(255)
  contact_number String    @db.VarChar(100)
  created_at     DateTime  @default(now())
  animals        Animal[]
  teams          Team[]
}

model Team {
  id              Int      @id @default(autoincrement())
  team_name       String   @db.VarChar(100)
  manager_agent_id Int?
  base_shelter_id Int
  manager         Agent?   @relation("TeamManager", fields: [manager_agent_id], references: [id])
  shelter         Shelter  @relation(fields: [base_shelter_id], references: [id])
  agents          Agent[]  @relation("TeamMembers")
  tickets         Ticket[]
}

model Agent {
  id             Int                @id @default(autoincrement())
  first_name     String             @db.VarChar(100)
  last_name      String             @db.VarChar(100)
  email          String             @unique @db.VarChar(255)
  password       String             @db.VarChar(255)
  phone          String             @db.VarChar(100)
  team_id        Int?
  role_id        Int
  status         String             @default("Active") @db.VarChar(50)
  team           Team?              @relation("TeamMembers", fields: [team_id], references: [id])
  role           Role               @relation(fields: [role_id], references: [id])
  managedTeams   Team[]             @relation("TeamManager")
  treatments     Animal_Treatment[]
}

model Incident_Report {
  id             Int      @id @default(autoincrement())
  reporter_name  String?  @db.VarChar(100)
  contact_number String?  @db.VarChar(100)
  is_anonymous   Boolean  @default(false)
  species_id     Int
  severity       String   @db.VarChar(50)
  status         String   @default("Pending") @db.VarChar(50)
  location       String   @db.VarChar(255)
  latitude       Float
  longitude      Float
  photo          String?  @db.VarChar(255)
  description    String   @db.Text
  created_at     DateTime @default(now())
  species        Species  @relation(fields: [species_id], references: [id])
  tickets        Ticket[]
}

model Ticket {
  id                     Int                @id @default(autoincrement())
  subject                String             @db.VarChar(255)
  incident_report_id     Int?
  rescue_date            DateTime?
  resolution_time        DateTime?
  rescue_notes           String             @db.Text
  raised_by              String?            @db.VarChar(255)
  status                 String             @default("REPORTED") @db.VarChar(50)
  priority               String             @db.VarChar(50)
  current_assigned_team_id Int?
  description            String             @db.Text
  created_at             DateTime           @default(now())
  incident_report        Incident_Report?   @relation(fields: [incident_report_id], references: [id])
  team                   Team?              @relation(fields: [current_assigned_team_id], references: [id])
  animals                Animal[]
  treatments             Animal_Treatment[]
}

model Animal {
  id            Int                @id @default(autoincrement())
  name          String             @db.VarChar(100)
  species_id    Int
  breed         String?            @db.VarChar(100)
  sex           String             @db.VarChar(50)
  age_estimate  String             @db.VarChar(50)
  weight        Float
  condition     String             @db.Text
  status        String             @db.VarChar(50)
  photo_url     String?            @db.VarChar(255)
  ticket_id     Int?
  shelter_id    Int?
  created_at    DateTime           @default(now())
  species       Species            @relation(fields: [species_id], references: [id])
  ticket        Ticket?            @relation(fields: [ticket_id], references: [id])
  shelter       Shelter?           @relation(fields: [shelter_id], references: [id])
  treatments    Animal_Treatment[]
}

model Animal_Treatment {
  id            Int       @id @default(autoincrement())
  animal_id     Int
  vet_agent_id  Int
  ticket_id     Int?
  followup_date DateTime?
  diagnosis     String    @db.Text
  treatment     String    @db.Text
  medication    String    @db.Text
  notes         String    @db.Text
  created_at    DateTime  @default(now())
  animal        Animal    @relation(fields: [animal_id], references: [id], onDelete: Cascade)
  vet           Agent     @relation(fields: [vet_agent_id], references: [id])
  ticket        Ticket?   @relation(fields: [ticket_id], references: [id])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  entity_type String   @db.VarChar(50)
  entity_id   Int
  action      String   @db.Text
  timestamp   DateTime @default(now())
  user        String   @db.VarChar(100)
}
